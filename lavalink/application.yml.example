server:
  port: 2333
  address: 0.0.0.0

lavalink:
  server:
    password: "your_lavalink_password"
    sources:
      youtube: true
      bandcamp: true
      soundcloud: true
      twitch: true
      vimeo: true
      http: true
    filterHotSwapEnabled: true
    youtubeSearchEnabled: true
    soundcloudSearchEnabled: true

logging:
  level:
    root: INFO

plugins:
  # Example for Lavasrc plugin (Spotify/YouTube Music resolvers).
  # You must download the plugin JAR and place it next to Lavalink.jar,
  # then configure credentials below.
  lavasrc:
    spotify:
      clientId: "your_spotify_client_id"
      clientSecret: "your_spotify_client_secret"
      countryCode: "US"
    youtubeMusic:
      enabled: true
