server:
  port: 2333
  address: 0.0.0.0

lavalink:
  server:
    password: "your_lavalink_password"
    sources:
      youtube: true
      bandcamp: true
      soundcloud: true
      twitch: true
      vimeo: true
      http: true
    filterHotSwapEnabled: true
    youtubeSearchEnabled: true
    soundcloudSearchEnabled: true

logging:
  level:
    root: INFO

  plugins:
    - dependency: "com.github.topi314.lavasrc:lavasrc-plugin:4.8.1"
      repository: "https://maven.lavalink.dev/releases"
      snapshot: false

plugins:
  # LavaSrc plugin config (Spotify/YouTube Music resolvers).
  # Lavalink will auto-download the plugin above on startup.
  lavasrc:
    sources:
      spotify: true
      youtube: true
      ytdlp: true
    spotify:
      clientId: "d07cf9fe03334a088a92f2ddc2b903ff"
      clientSecret: "f6bc028d512f475d9d3d1dd462f5fa40"
      countryCode: "US"
    providers:
      - "ytsearch:\"%ISRC%\""
      - "ytsearch:%QUERY%"
