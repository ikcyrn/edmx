server:
  port: 2333
  address: 0.0.0.0

lavalink:
  server:
    password: "your_lavalink_password"
    sources:
      youtube: false
      bandcamp: true
      soundcloud: true
      twitch: true
      vimeo: true
      http: true
    filterHotSwapEnabled: true
    youtubeSearchEnabled: true
    soundcloudSearchEnabled: true
  plugins:
    - dependency: "dev.lavalink.youtube:youtube-plugin:1.18.0"
      repository: "https://maven.lavalink.dev/releases"
      snapshot: false
    - dependency: "com.github.topi314.lavasrc:lavasrc-plugin:4.8.1"
      repository: "https://maven.lavalink.dev/releases"
      snapshot: false

logging:
  level:
    root: INFO
    dev.lavalink.youtube.http.YoutubeOauth2Handler: INFO

plugins:
  youtube:
    enabled: true
    allowSearch: true
    cookies: "/opt/cookies.txt"
    clients:
      - WEB
      - WEBEMBEDDED
      - MWEB
    oauth:
      enabled: true
  # LavaSrc plugin config (Spotify/YouTube Music resolvers).
  # Lavalink will auto-download the plugin above on startup.
  lavasrc:
    sources:
      spotify: true
      youtube: true
      ytdlp: false
    spotify:
      clientId: "your_spotify_client_id"
      clientSecret: "your_spotify_client_secret"
      countryCode: "US"
    providers:
      - "ytsearch:\"%ISRC%\""
      - "ytsearch:%QUERY%"
